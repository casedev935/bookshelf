CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- Usuários
CREATE TABLE users (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    name VARCHAR(100) NOT NULL,
    email VARCHAR(150) UNIQUE NOT NULL,
    password_hash TEXT NOT NULL,
    profile_picture_url TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- Categorias (Ficção, Drama, TI, etc.)
CREATE TABLE categories (
    id SERIAL PRIMARY KEY,
    name VARCHAR(50) NOT NULL UNIQUE
);

-- Filmes
CREATE TABLE movies (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    user_id UUID REFERENCES users(id) ON DELETE CASCADE,
    title VARCHAR(255) NOT NULL,
    release_year INTEGER,
    director VARCHAR(255),
    category_id INTEGER REFERENCES categories(id),
    poster_url TEXT,
    status VARCHAR(20) CHECK (status IN ('assistido', 'na fila')),
    watched_at DATE, -- Nova coluna solicitada
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- Livros
CREATE TABLE books (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    user_id UUID REFERENCES users(id) ON DELETE CASCADE,
    title VARCHAR(255) NOT NULL,
    release_year INTEGER,
    author VARCHAR(255),
    category_id INTEGER REFERENCES categories(id),
    cover_url TEXT,
    status VARCHAR(20) CHECK (status IN ('lido', 'lendo', 'na fila')),
    started_reading_at DATE,
    finished_reading_at DATE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- Índices para performance (50 usuários, foco em busca e filtro)
CREATE INDEX idx_movies_user_status ON movies(user_id, status);
CREATE INDEX idx_books_user_status ON books(user_id, status);