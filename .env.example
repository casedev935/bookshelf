# =============================================================
# .env.example — Raiz do Monorepo (Docker Compose)
# Copie para .env e preencha os valores reais.
# NUNCA commite o arquivo .env!
# =============================================================

# --- Banco de Dados (PostgreSQL) ---
DB_USER=postgres
DB_PASSWORD=TROQUE_POR_SENHA_FORTE
DB_NAME=bookshelf

# --- Conexão do Prisma (usada pela API localmente) ---
# Em produção, mude @localhost para o nome do serviço Docker (ex: @database)
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}?schema=public"

# --- Chave secreta JWT ---
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UM_SEGREDO_FORTE_E_ALEATORIO

# --- TMDB (The Movie Database) ---
TMDB_API_KEY=SUA_CHAVE_AQUI
TMDB_BASE_URL=https://api.themoviedb.org/3
