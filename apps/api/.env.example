# =============================================================
# .env.example — App API (NestJS)
# Copie para .env e preencha os valores reais.
# NUNCA commite o arquivo .env!
# =============================================================

# --- Banco de Dados ---
# Local: aponta para localhost. Produção: aponta para o serviço Docker (ex: @database)
DATABASE_URL="postgresql://postgres:TROQUE_POR_SENHA_FORTE@localhost:5432/bookshelf?schema=public"

# --- JWT ---
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UM_SEGREDO_FORTE_E_ALEATORIO

# --- TMDB ---
TMDB_API_KEY=SUA_CHAVE_AQUI
TMDB_BASE_URL=https://api.themoviedb.org/3

# --- Servidor ---
PORT=3001

# --- CORS ---
# Desenvolvimento: http://localhost:3000
# Produção: https://seudominio.com
CORS_ORIGIN=http://localhost:3000
