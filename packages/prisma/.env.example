# --- Conexão do Banco de Dados ---
# Usada pelo Prisma CLI (migrations, seed, studio)
# Local: aponta para localhost
# Produção: aponta para o serviço Docker (ex: @database)
DATABASE_URL="postgresql://postgres:TROQUE_POR_SENHA_FORTE@localhost:5432/bookshelf?schema=public"
