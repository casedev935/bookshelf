generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  name                String    @db.VarChar(100)
  email               String    @unique @db.VarChar(150)
  username            String?   @unique @db.VarChar(50)
  is_public           Boolean   @default(false)
  password_hash       String
  profile_picture_url String?
  created_at          DateTime  @default(now()) @db.Timestamptz
  
  movies              Movie[]
  books               Book[]
  series              Series[]

  @@map("users")
}

enum CategoryType {
  movie
  book
  series
}

model Category {
  id    Int          @id @default(autoincrement())
  name  String       @db.VarChar(50)
  type  CategoryType
 
  movies Movie[]
  books  Book[]
  series Series[]
 
  @@unique([name, type])
  @@map("categories")
}

enum MovieStatus {
  assistido
  na_fila
  proximo
}

model Movie {
  id           String       @id @default(uuid()) @db.Uuid
  user_id      String       @db.Uuid
  title        String       @db.VarChar(255)
  release_year Int?
  director     String?      @db.VarChar(255)
  category_id  Int?
  poster_url   String?
  status       MovieStatus?
  watched_at   DateTime?    @db.Date
  created_at   DateTime     @default(now()) @db.Timestamptz

  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [category_id], references: [id])

  @@map("movies")
  @@index([user_id, status])
}

enum BookStatus {
  lido
  lendo
  na_fila
  proximo
}

model Book {
  id                  String      @id @default(uuid()) @db.Uuid
  user_id             String      @db.Uuid
  title               String      @db.VarChar(255)
  release_year        Int?
  author              String?     @db.VarChar(255)
  category_id         Int?
  cover_url           String?
  status              BookStatus?
  started_reading_at  DateTime?   @db.Date
  finished_reading_at DateTime?   @db.Date
  created_at          DateTime    @default(now()) @db.Timestamptz

  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [category_id], references: [id])

  @@map("books")
  @@index([user_id, status])
}

enum SeriesStatus {
  assistindo
  finalizada
  na_fila
  proximo
}

model Series {
  id           String        @id @default(uuid()) @db.Uuid
  user_id      String        @db.Uuid
  title        String        @db.VarChar(255)
  release_year Int?
  category_id  Int?
  poster_url   String?
  status       SeriesStatus?
  created_at   DateTime      @default(now()) @db.Timestamptz

  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [category_id], references: [id])

  @@map("series")
  @@index([user_id, status])
}
